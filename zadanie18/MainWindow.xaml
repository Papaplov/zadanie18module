<Window x:Class="zadanie18.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Библиотека" Height="550" Width="850">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Поиск -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <Label Content="Поиск:" VerticalAlignment="Center"/>
            <TextBox x:Name="SearchTextBox" Width="200" Margin="5,0" VerticalAlignment="Center" TextChanged="SearchTextBox_TextChanged"/>
        </StackPanel>

        <!-- Сортировка и фильтр -->
        <WrapPanel Grid.Row="1" Margin="0,0,0,10">
            <Label Content="Сортировать по:" VerticalAlignment="Center"/>
            <ComboBox x:Name="SortComboBox" Width="120" Margin="5,0" SelectionChanged="SortComboBox_SelectionChanged">
                <ComboBoxItem Content="Название" Tag="Title" IsSelected="True"/>
                <ComboBoxItem Content="Автор" Tag="Author"/>
                <ComboBoxItem Content="Год" Tag="YearOfPublication"/>
                <ComboBoxItem Content="Цена" Tag="Price"/>
                <ComboBoxItem Content="Издательство" Tag="Publisher"/>
            </ComboBox>

            <Label Content="Жанр:" VerticalAlignment="Center" Margin="15,0,0,0"/>
            <ComboBox x:Name="GenreComboBox" Width="150" Margin="5,0" SelectionChanged="GenreComboBox_SelectionChanged"/>
        </WrapPanel>

        <!-- Кнопки управления -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,10">
            <Button x:Name="AddButton" Content="Добавить" Width="80" Margin="0,0,10,0" Click="AddButton_Click"/>
            <Button x:Name="DeleteButton" Content="Удалить" Width="80" Margin="0,0,10,0" Click="DeleteButton_Click"/>
            <Button x:Name="SaveButton" Content="Сохранить" Width="80" Click="SaveButton_Click"/>
        </StackPanel>

        <!-- DataGrid -->
        <DataGrid x:Name="BooksDataGrid" Grid.Row="3" 
                  AutoGenerateColumns="False" 
                  CanUserAddRows="False" 
                  CanUserDeleteRows="False"
                  AlternatingRowBackground="LightGray"
                  SelectionMode="Single" SelectionUnit="FullRow">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Название" Binding="{Binding Title, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                <DataGridTextColumn Header="Автор" Binding="{Binding Author, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                <DataGridTextColumn Header="Издательство" Binding="{Binding Publisher, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                <DataGridTextColumn Header="Год" Binding="{Binding YearOfPublication, UpdateSourceTrigger=PropertyChanged}" Width="80"/>
                <DataGridTextColumn Header="Цена" Binding="{Binding Price, UpdateSourceTrigger=PropertyChanged}" Width="80"/>
                <DataGridComboBoxColumn Header="Жанр" 
                                        SelectedItemBinding="{Binding Genres, UpdateSourceTrigger=PropertyChanged}"
                                        DisplayMemberPath="Name"
                                        SelectedValuePath="Id">
                    <DataGridComboBoxColumn.ElementStyle>
                        <Style TargetType="ComboBox">
                            <Setter Property="ItemsSource" Value="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Window}}, Path=Genres}"/>
                        </Style>
                    </DataGridComboBoxColumn.ElementStyle>
                    <DataGridComboBoxColumn.EditingElementStyle>
                        <Style TargetType="ComboBox">
                            <Setter Property="ItemsSource" Value="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Window}}, Path=Genres}"/>
                        </Style>
                    </DataGridComboBoxColumn.EditingElementStyle>
                </DataGridComboBoxColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>